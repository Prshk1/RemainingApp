{
  "expo": {
    "name": "Remaining",
    "slug": "RemainingApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/RemainingLogo-Foreground.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/RemainingLogo-Splash.png",
      "resizeMode": "contain",
      "imageWidth": 360,
      "backgroundColor": "#0B0616"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prshk1.remaining",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/RemainingLogo-Foreground.png",
        "backgroundColor": "#0B0616",
        "monochromeImage": "./assets/RemainingLogo-monochrome.png",
        "safeMargins": true
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.prshk1.remaining",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/RemainingLogo-Foreground.png"
    },
    "extra": {
      "eas": {
        "projectId": "3542eca5-865e-459c-8efc-faf5f93522ca"
      }
    },
    "owner": "prshk1",
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Remaining to save photos to your gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Remaining to access your photo library."
        }
      ]
    ]
  }
}
